#!/bin/sh
# Fail commits if built CV HTML still contains the source placeholder (run ./build.sh).
set -e
REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

for f in cv.html full-cv.html; do
	if [ ! -f "$f" ]; then
		continue
	fi
	if grep -q '__BUILD_DATE__' "$f"; then
		echo "pre-commit: $f still contains __BUILD_DATE__. Run ./build.sh and git add $f." >&2
		exit 1
	fi
done

exit 0
